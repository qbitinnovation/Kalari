PORT=5000

# Atlas: if mongodb+srv:// fails with querySrv ECONNREFUSED, use the standard (non-SRV) string from Atlas Connect, or local:
# MONGODB_URI=mongodb://127.0.0.1:27017/kalari_booking
MONGODB_URI=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Optional: seeded into MongoDB `users` on startup (bcrypt). Login still checks the database only.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change-me
# STAFF_EMAIL=staff@example.com
# STAFF_PASSWORD=change-me
# Set to true once if you changed .env password but the user already exists: SYNC_BOOTSTRAP_PASSWORDS=true
